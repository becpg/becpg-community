							<control-param name="ds">becpg/autocomplete/targetassoc/associations/pjt:scoreCriterion</control-param>
							<control-param name="showTooltip">false</control-param>
							<control-param name="saveTitle">false</control-param>
						</control>
					</field>


				</appearance>
			</form>
		</forms>
